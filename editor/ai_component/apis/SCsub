#!/usr/bin/env python
from misc.utility.scons_hints import *
Import("env")

# 添加生成JSON头文件的自定义构建器
def generate_json_header(target, source, env):
    import os
    import subprocess
    
    # 获取源文件和目标文件路径
    json_path = source[0].get_abspath()
    header_path = target[0].get_abspath()
    
    # 创建目标目录（如果不存在）
    header_dir = os.path.dirname(header_path)
    if not os.path.exists(header_dir):
        os.makedirs(header_dir, exist_ok=True)
    
    # 创建生成命令
    cmd = [
        "python",  # 明确使用python3
        "editor/ai_component/apis/generate_json_header.py",
        json_path, 
        header_path
    ]
    
    print(f"Generating JSON header: {header_path} from {json_path}")
    
    # 执行命令
    result = subprocess.run(cmd, capture_output=True, text=True)
    
    # 检查执行结果
    if result.returncode != 0:
        print(f"Error generating JSON header (code {result.returncode}):\n{result.stderr}")
        return result.returncode  # 返回实际错误码
    
    print(f"Successfully generated {header_path}")
    print(result.stdout)
    
    # 验证生成的文件是否存在
    if not os.path.exists(header_path):
        print(f"ERROR: Generated file {header_path} does not exist!")
        return 1
    
    return 0  # 返回0表示成功

# 添加生成Markdown头文件的自定义构建器
def generate_md_header(target, source, env):
    import os
    import subprocess
    
    # 获取源文件和目标文件路径
    md_path = source[0].get_abspath()
    header_path = target[0].get_abspath()
    
    # 创建目标目录（如果不存在）
    header_dir = os.path.dirname(header_path)
    if not os.path.exists(header_dir):
        os.makedirs(header_dir, exist_ok=True)
    
    # 创建生成命令
    cmd = [
        "python",  # 明确使用python3
        "editor/ai_component/apis/generate_md_header.py",
        md_path, 
        header_path
    ]
    
    print(f"Generating Markdown header: {header_path} from {md_path}")
    
    # 执行命令
    result = subprocess.run(cmd, capture_output=True, text=True)
    
    # 检查执行结果
    if result.returncode != 0:
        print(f"Error generating Markdown header (code {result.returncode}):\n{result.stderr}")
        return result.returncode  # 返回实际错误码
    
    print(f"Successfully generated {header_path}")
    print(result.stdout)
    
    # 验证生成的文件是否存在
    if not os.path.exists(header_path):
        print(f"ERROR: Generated file {header_path} does not exist!")
        return 1
    
    return 0  # 返回0表示成功

# 注册自定义构建器
env.Append(BUILDERS={
    'GenerateJsonHeader': env.Builder(
        action=env.Action(generate_json_header),
        suffix='.h',
        src_suffix='.json'
    ),
    'GenerateMdHeader': env.Builder(
        action=env.Action(generate_md_header),
        suffix='.h',
        src_suffix='.md'
    )
})

json_header = env.GenerateJsonHeader(
    target='tools_json.h', 
    source='tools.json'
)

md_header = env.GenerateMdHeader(
    target='system_prompt.h', 
    source='system_prompt.md'
)

env.Precious(json_header)  # 标记为重要文件
env.NoClean(json_header)   # 禁止清理
env.Precious(md_header)    # 标记为重要文件
env.NoClean(md_header)     # 禁止清理

# 确保编辑器源文件依赖生成的JSON头文件
env.Depends(env.editor_sources, json_header)
env.Depends(env.editor_sources, md_header)

# 添加源文件（确保在生成头文件之后）
env.add_source_files(env.editor_sources, "*.cpp")
